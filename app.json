{
  "expo": {
    "name": "HeadTrack Nepal",
    "slug": "headtrack-nepal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "headtracknepal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "android": {
      "package": "org.sunthanphc.headtracknepal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F6F8FA"
      },
      "blockedPermissions": [
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6F8FA"
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "defaultChannel": "daily-reminder"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e5c1a151-7ceb-41b8-8882-066cd47599c1"
      }
    },
    "owner": "robinn"
  }
}
